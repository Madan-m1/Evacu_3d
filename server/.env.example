# MongoDB connection string (Required for persistence)
MONGODB_URI=mongodb://localhost:27017/evacu3d

# Server configuration
PORT=5005
JWT_SECRET=your_super_secret_jwt_key
NODE_ENV=development

# Optional: Initial Admin Secure Setup
# If set, these will create the first administrator on boot.
# MASTER_ADMIN_EMAIL=admin@evacu3d.com
# MASTER_ADMIN_PASSWORD=ComplexPassword123!

# Production Frontend URL for CORS
# FRONTEND_URL=https://yourdomain.com
